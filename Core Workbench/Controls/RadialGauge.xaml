<UserControl x:Class="Core_Workbench.Controls.RadialGauge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="108" Height="108">
    <Grid>
        <Path x:Name="Track" Stroke="{StaticResource SurfaceAltBrush}" StrokeThickness="9"
              StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
        <Path x:Name="Progress" Stroke="{StaticResource AccentBrush}" StrokeThickness="9"
              StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="ValueTextRun" Text="0%" FontSize="21" FontWeight="Bold"
                       HorizontalAlignment="Center" Foreground="{StaticResource TextBrush}" />
            <TextBlock x:Name="CaptionText" Text="" Style="{StaticResource SubtleText}"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>

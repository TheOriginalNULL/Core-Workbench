<UserControl x:Class="Core_Workbench.Views.WidgetsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <UserControl.Resources>
        <Style x:Key="AddCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="6" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
        <StackPanel Margin="26,26,26,20">
            <TextBlock Text="Widgets" Style="{StaticResource HeaderText}" />
            <TextBlock Text="Add live widgets to your desktop" Style="{StaticResource SubtleText}"
                       Margin="0,2,0,0" />

            <!-- Add a widget -->
            <TextBlock Text="ADD A WIDGET" Style="{StaticResource SectionLabel}" Margin="8,22,0,8" />

            <!-- Combined system bar (recommended) -->
            <Border Style="{StaticResource AddCard}" Tag="Bar" MouseLeftButtonUp="Add_Click">
                <StackPanel Orientation="Horizontal">
                    <Path Width="26" Height="26" Stretch="Uniform" Data="{StaticResource IconDashboard}"
                          Stroke="{StaticResource Accent2Brush}" StrokeThickness="1.7" StrokeLineJoin="Round"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" VerticalAlignment="Center" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="System bar" FontWeight="SemiBold" FontSize="14" />
                        <TextBlock Text="One connected bar: CPU, GPU, RAM live graphs + clock"
                                   Style="{StaticResource SubtleText}" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="…or individual widgets" Style="{StaticResource SubtleText}" Margin="8,12,0,6" />
            <UniformGrid Columns="4">
                <Border Style="{StaticResource AddCard}" Tag="Cpu" MouseLeftButtonUp="Add_Click">
                    <StackPanel>
                        <Path Width="24" Height="24" Stretch="Uniform" Data="{StaticResource IconDashboard}"
                              Stroke="{StaticResource Accent2Brush}" StrokeThickness="1.7" StrokeLineJoin="Round"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" HorizontalAlignment="Left" />
                        <TextBlock Text="CPU usage" FontWeight="SemiBold" FontSize="14" Margin="0,12,0,0" />
                        <TextBlock Text="Live processor load + temp" Style="{StaticResource SubtleText}"
                                   TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource AddCard}" Tag="Gpu" MouseLeftButtonUp="Add_Click">
                    <StackPanel>
                        <Path Width="24" Height="24" Stretch="Uniform" Data="{StaticResource IconDashboard}"
                              Stroke="{StaticResource Accent2Brush}" StrokeThickness="1.7" StrokeLineJoin="Round"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" HorizontalAlignment="Left" />
                        <TextBlock Text="GPU usage" FontWeight="SemiBold" FontSize="14" Margin="0,12,0,0" />
                        <TextBlock Text="Live graphics load + temp" Style="{StaticResource SubtleText}"
                                   TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource AddCard}" Tag="Ram" MouseLeftButtonUp="Add_Click">
                    <StackPanel>
                        <Path Width="24" Height="24" Stretch="Uniform" Data="{StaticResource IconDashboard}"
                              Stroke="{StaticResource Accent2Brush}" StrokeThickness="1.7" StrokeLineJoin="Round"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" HorizontalAlignment="Left" />
                        <TextBlock Text="Memory" FontWeight="SemiBold" FontSize="14" Margin="0,12,0,0" />
                        <TextBlock Text="Live RAM usage" Style="{StaticResource SubtleText}"
                                   TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource AddCard}" Tag="Clock" MouseLeftButtonUp="Add_Click">
                    <StackPanel>
                        <Path Width="24" Height="24" Stretch="Uniform" Data="{StaticResource IconClock}"
                              Stroke="{StaticResource Accent2Brush}" StrokeThickness="1.7" StrokeLineJoin="Round"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" HorizontalAlignment="Left" />
                        <TextBlock Text="Clock" FontWeight="SemiBold" FontSize="14" Margin="0,12,0,0" />
                        <TextBlock Text="Time &amp; date" Style="{StaticResource SubtleText}"
                                   TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TextBlock Text="Tip: pin any note as a widget from the Notes tab (📌 Pin as widget)."
                       Style="{StaticResource SubtleText}" Margin="8,10,0,0" />

            <!-- Active widgets -->
            <TextBlock Text="ACTIVE WIDGETS" Style="{StaticResource SectionLabel}" Margin="8,24,0,8" />
            <ItemsControl x:Name="ActiveList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBrush}" CornerRadius="10"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Padding="16,12" Margin="6,0,6,8">
                            <Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TitleLabel}" FontWeight="SemiBold" FontSize="14"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Type}" Style="{StaticResource SubtleText}"
                                               Margin="0,1,0,0" />
                                </StackPanel>
                                <Button Content="Remove" Style="{StaticResource GhostButton}" Padding="12,6"
                                        FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Tag="{Binding}" Click="Remove_Click" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock x:Name="EmptyActive" Text="No widgets on your desktop yet."
                       Style="{StaticResource SubtleText}" Margin="8,2,0,0" Visibility="Collapsed" />
        </StackPanel>
    </ScrollViewer>
</UserControl>

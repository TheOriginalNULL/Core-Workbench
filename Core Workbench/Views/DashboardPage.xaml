<UserControl x:Class="Core_Workbench.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <UserControl.Resources>
        <!-- Clickable quick-access card -->
        <Style x:Key="QuickCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
        <StackPanel Margin="32,28,32,20">

            <!-- Greeting -->
            <TextBlock x:Name="GreetingText" Text="Welcome back" Style="{StaticResource HeaderText}" />
            <TextBlock x:Name="DateText" Style="{StaticResource SubtleText}" Margin="0,2,0,0" />

            <!-- Daily message -->
            <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,22,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✦" FontSize="22" VerticalAlignment="Center" Margin="0,0,14,0"
                               Foreground="{StaticResource Accent2Brush}" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="MESSAGE OF THE DAY" Style="{StaticResource SectionLabel}" />
                        <TextBlock x:Name="DailyText" FontSize="15" Margin="0,3,0,0"
                                   TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Quick access -->
            <TextBlock Text="QUICK ACCESS" Style="{StaticResource SectionLabel}" Margin="2,26,0,12" />
            <UniformGrid Rows="1" Columns="3">

                <Border Style="{StaticResource QuickCard}" Tag="Performance" Margin="0,0,6,0"
                        MouseLeftButtonUp="Quick_Click">
                    <StackPanel>
                        <Border Width="42" Height="42" CornerRadius="11" HorizontalAlignment="Left"
                                Background="{StaticResource SurfaceAltBrush}">
                            <Path Width="22" Height="22" Stretch="Uniform" Data="{StaticResource IconDashboard}"
                                  Stroke="{StaticResource Accent2Brush}" StrokeThickness="1.7"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Performance" FontWeight="SemiBold" FontSize="15" Margin="0,12,0,0" />
                        <TextBlock Text="Live CPU, GPU, RAM &amp; disk usage" Style="{StaticResource SubtleText}"
                                   TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource QuickCard}" Tag="Notes" Margin="6,0,6,0"
                        MouseLeftButtonUp="Quick_Click">
                    <StackPanel>
                        <Border Width="42" Height="42" CornerRadius="11" HorizontalAlignment="Left"
                                Background="{StaticResource SurfaceAltBrush}">
                            <Path Width="22" Height="22" Stretch="Uniform" Data="{StaticResource IconNotes}"
                                  Stroke="{StaticResource Accent2Brush}" StrokeThickness="1.7"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Notes" FontWeight="SemiBold" FontSize="15" Margin="0,12,0,0" />
                        <TextBlock Text="Jot things down, autosaved" Style="{StaticResource SubtleText}"
                                   TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource QuickCard}" Tag="Cleaner" Margin="6,0,0,0"
                        MouseLeftButtonUp="Quick_Click">
                    <StackPanel>
                        <Border Width="42" Height="42" CornerRadius="11" HorizontalAlignment="Left"
                                Background="{StaticResource SurfaceAltBrush}">
                            <Path Width="22" Height="22" Stretch="Uniform" Data="{StaticResource IconCleaner}"
                                  Stroke="{StaticResource Accent2Brush}" StrokeThickness="1.7"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Cleaner" FontWeight="SemiBold" FontSize="15" Margin="0,12,0,0" />
                        <TextBlock Text="Free up disk space fast" Style="{StaticResource SubtleText}"
                                   TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>

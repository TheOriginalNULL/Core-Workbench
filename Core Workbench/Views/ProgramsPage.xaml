<UserControl x:Class="Core_Workbench.Views.ProgramsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <Grid Margin="32,26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Apps" Style="{StaticResource HeaderText}" />
                <TextBlock x:Name="SubText" Text="Installed programs &amp; games"
                           Style="{StaticResource SubtleText}" Margin="0,2,0,0" />
            </StackPanel>
            <Button x:Name="RefreshButton" Content="Refresh" Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Right" VerticalAlignment="Center" Click="Refresh_Click" />
        </Grid>

        <!-- Search -->
        <TextBox x:Name="SearchBox" Grid.Row="1" Margin="0,16,0,0" Height="40"
                 VerticalContentAlignment="Center" Padding="12,0" TextChanged="Search_TextChanged" />

        <!-- Sort + size filter -->
        <WrapPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock Text="Sort" Style="{StaticResource SubtleText}" VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <Button x:Name="SortName" Content="Name" Style="{StaticResource GhostButton}" Padding="12,6"
                    FontSize="12" Margin="0,0,4,0" Tag="Name" Click="Sort_Click" />
            <Button x:Name="SortLargest" Content="Largest" Style="{StaticResource GhostButton}" Padding="12,6"
                    FontSize="12" Margin="0,0,4,0" Tag="Largest" Click="Sort_Click" />
            <Button x:Name="SortSmallest" Content="Smallest" Style="{StaticResource GhostButton}" Padding="12,6"
                    FontSize="12" Margin="0,0,4,0" Tag="Smallest" Click="Sort_Click" />

            <Border Width="1" Background="{StaticResource BorderBrush}" Margin="10,2,10,2" />

            <TextBlock Text="Min size" Style="{StaticResource SubtleText}" VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <Button x:Name="SizeAll" Content="All" Style="{StaticResource GhostButton}" Padding="12,6"
                    FontSize="12" Margin="0,0,4,0" Tag="0" Click="Size_Click" />
            <Button x:Name="Size100" Content="100MB+" Style="{StaticResource GhostButton}" Padding="12,6"
                    FontSize="12" Margin="0,0,4,0" Tag="104857600" Click="Size_Click" />
            <Button x:Name="Size1G" Content="1GB+" Style="{StaticResource GhostButton}" Padding="12,6"
                    FontSize="12" Margin="0,0,4,0" Tag="1073741824" Click="Size_Click" />
            <Button x:Name="Size5G" Content="5GB+" Style="{StaticResource GhostButton}" Padding="12,6"
                    FontSize="12" Tag="5368709120" Click="Size_Click" />
        </WrapPanel>

        <!-- List -->
        <ScrollViewer Grid.Row="3" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
            <StackPanel>
                <ItemsControl x:Name="AppList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBrush}" CornerRadius="10"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Padding="14,11" Margin="0,0,0,7">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10"
                                            Background="{StaticResource SurfaceAltBrush}" VerticalAlignment="Center"
                                            Margin="0,0,12,0">
                                        <Path Width="20" Height="20" Stretch="Uniform" Data="{StaticResource IconApps}"
                                              Stroke="{StaticResource Accent2Brush}" StrokeThickness="1.4"
                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Detail}" Style="{StaticResource SubtleText}"
                                                   TextTrimming="CharacterEllipsis" Margin="0,1,0,0" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Text="{Binding SizeText}" Style="{StaticResource SubtleText}"
                                               VerticalAlignment="Center" Margin="12,0,16,0" />

                                    <Button Grid.Column="3" Content="Uninstall" Style="{StaticResource DangerButton}"
                                            Padding="12,6" FontSize="12" VerticalAlignment="Center"
                                            Tag="{Binding}" Click="Uninstall_Click" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock x:Name="EmptyText" Style="{StaticResource SubtleText}" Margin="2,4,0,0"
                           Visibility="Collapsed" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

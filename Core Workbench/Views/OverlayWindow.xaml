<Window x:Class="Core_Workbench.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        mc:Ignorable="d"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Overlay" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" Topmost="True"
        SizeToContent="WidthAndHeight" ShowActivated="False"
        FontFamily="Consolas">
    <Border x:Name="Backplate" CornerRadius="8" Background="#B2000000" Padding="12,9">
        <StackPanel x:Name="Lines" />
    </Border>
</Window>

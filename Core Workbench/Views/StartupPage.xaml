<UserControl x:Class="Core_Workbench.Views.StartupPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <Grid Margin="32,26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Startup" Style="{StaticResource HeaderText}" />
                <TextBlock x:Name="SubText" Text="Programs that launch when you sign in"
                           Style="{StaticResource SubtleText}" Margin="0,2,0,0" />
            </StackPanel>
            <Button x:Name="RefreshButton" Content="Refresh" Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Right" VerticalAlignment="Center" Click="Refresh_Click" />
        </Grid>

        <!-- List -->
        <ScrollViewer Grid.Row="1" Margin="0,18,0,0" VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
            <StackPanel>
                <ItemsControl x:Name="StartupList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBrush}" CornerRadius="10"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Padding="16,12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding LocationLabel}" Style="{StaticResource SubtleText}"
                                                   Margin="0,1,0,0" />
                                        <TextBlock Text="{Binding Command}" Style="{StaticResource SubtleText}"
                                                   FontSize="11" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Command}" Margin="0,2,0,0" />
                                    </StackPanel>

                                    <CheckBox Grid.Column="1" Content="Enabled" IsChecked="{Binding Enabled, Mode=OneWay}"
                                              VerticalAlignment="Center" Margin="0,0,14,0"
                                              Click="Toggle_Click" Tag="{Binding}" />

                                    <Button Grid.Column="2" Content="Remove" Style="{StaticResource GhostButton}"
                                            Padding="12,6" FontSize="12" VerticalAlignment="Center"
                                            Click="Remove_Click" Tag="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock x:Name="EmptyText" Text="No startup entries found." Style="{StaticResource SubtleText}"
                           Margin="2,4,0,0" Visibility="Collapsed" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

<Window x:Class="Core_Workbench.Views.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        mc:Ignorable="d"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Widget" Width="300" Height="340" MinWidth="150" MinHeight="80"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" Topmost="True"
        Icon="/Assets/SecondaryLogo.ico">

    <Grid>
    <Border CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            Background="#E61A1133">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="18" ShadowDepth="0" Opacity="0.5" />
        </Border.Effect>
        <DockPanel>
            <Grid DockPanel.Dock="Top" Height="34" Background="Transparent"
                  MouseLeftButtonDown="Header_Down" MouseMove="Header_Move" MouseLeftButtonUp="Header_Up">
                <TextBlock x:Name="TitleText" Margin="12,0,0,0" VerticalAlignment="Center"
                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource TextBrush}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,4,0">
                    <!-- Controls stay hidden until the mouse is over the widget. -->
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Value="True"
                                             Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Button x:Name="DesktopButton" Style="{StaticResource ToolBtn}" Width="34"
                            Click="Desktop_Click" ToolTip="Pin to desktop / floating">
                        <TextBlock Text="🖥" FontSize="12" />
                    </Button>
                    <Button x:Name="PinButton" Style="{StaticResource ToolBtn}" Width="34"
                            Click="Pin_Click" ToolTip="Always on top (floating mode)">
                        <TextBlock Text="📌" FontSize="12" />
                    </Button>
                    <Button Style="{StaticResource ToolBtn}" Width="34" Click="Close_Click"
                            ToolTip="Close widget">
                        <TextBlock Text="✕" FontSize="12" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Type-specific content goes here -->
            <ContentControl x:Name="Body" Margin="8,0,8,8" />
        </DockPanel>
    </Border>

        <!-- Custom resize grip — only visible on hover -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="18" Height="18"
                Margin="0,0,3,3" Background="Transparent" Cursor="SizeNWSE"
                MouseLeftButtonDown="Grip_Down" MouseMove="Grip_Move" MouseLeftButtonUp="Grip_Up">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Value="True"
                                     Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Window}}">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Path Data="M3 17 L17 3 M8 17 L17 8 M13 17 L17 13" Stroke="{StaticResource TextMutedBrush}"
                  StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
        </Border>
    </Grid>
</Window>

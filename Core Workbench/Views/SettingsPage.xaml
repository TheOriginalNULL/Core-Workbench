<UserControl x:Class="Core_Workbench.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
        <StackPanel Margin="32,26,32,20" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="Settings" Style="{StaticResource HeaderText}" />
            <TextBlock Text="App behaviour and startup" Style="{StaticResource SubtleText}" Margin="0,2,0,0" />

            <!-- Startup -->
            <TextBlock Text="STARTUP" Style="{StaticResource SectionLabel}" Margin="2,24,0,8" />
            <Border Style="{StaticResource Card}">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Start with Windows" FontWeight="SemiBold" />
                        <TextBlock Text="Launch Core Workbench automatically at sign-in (elevated, via a scheduled task)."
                                   Style="{StaticResource SubtleText}" TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                    <CheckBox x:Name="AutostartCheck" HorizontalAlignment="Right" VerticalAlignment="Center"
                              Click="Autostart_Click" />
                </Grid>
            </Border>

            <!-- Tray -->
            <TextBlock Text="SYSTEM TRAY" Style="{StaticResource SectionLabel}" Margin="2,20,0,8" />
            <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Minimize to tray" FontWeight="SemiBold" />
                        <TextBlock Text="When minimized, hide to the system tray instead of the taskbar."
                                   Style="{StaticResource SubtleText}" TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                    <CheckBox x:Name="MinTrayCheck" HorizontalAlignment="Right" VerticalAlignment="Center"
                              Click="MinTray_Click" />
                </Grid>
            </Border>
            <Border Style="{StaticResource Card}">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Close to tray" FontWeight="SemiBold" />
                        <TextBlock Text="The × button keeps the app running in the tray. Right-click the tray icon → Exit to quit."
                                   Style="{StaticResource SubtleText}" TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                    <CheckBox x:Name="CloseTrayCheck" HorizontalAlignment="Right" VerticalAlignment="Center"
                              Click="CloseTray_Click" />
                </Grid>
            </Border>

            <!-- About -->
            <TextBlock Text="ABOUT" Style="{StaticResource SectionLabel}" Margin="2,20,0,8" />
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Privileges" Style="{StaticResource SubtleText}" />
                        <TextBlock x:Name="AdminText" HorizontalAlignment="Right" FontWeight="SemiBold" />
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Runtime" Style="{StaticResource SubtleText}" />
                        <TextBlock x:Name="RuntimeText" HorizontalAlignment="Right" FontWeight="SemiBold" />
                    </Grid>
                    <Grid>
                        <TextBlock Text="Data folder" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                        <Button Content="Open" Style="{StaticResource GhostButton}" Padding="12,6"
                                HorizontalAlignment="Right" Click="OpenData_Click" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
